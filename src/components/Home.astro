---
import Base from '../layouts/Base.astro';
import PostList from './PostList.astro';
import { defaultLang, languages, localizePath, useTranslations, type Lang } from '../i18n/ui';
import { getPosts } from '../lib/blog';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const posts = await getPosts(lang);
const langCount = Object.keys(languages).length;

// Language-neutral proper nouns — not dictionary material.
const STACK = ['Nuxt', 'Vue', 'React', 'Node', 'Express', 'NestJS'];
const PROJECTS = [
  { name: 'tech-rea.com', url: 'https://tech-rea.com/' },
  { name: '360.8prop.com', url: 'https://360.8prop.com/' },
  { name: 'real-agent.ai', url: 'https://real-agent.ai/' },
];
---

<Base title={t('site.title')}>
  <article class="home-intro">
  <div class="hero">
    <span class="badge">{t('home.kicker')}</span>
    <h1>{t('home.greeting')}</h1>
    <p class="intro">{t('home.intro')}</p>
    <p class="intro">
      {t('home.ideas.before')}<a href={localizePath('/ideas/', lang)}>{t('home.ideas.link')}</a>{t('home.ideas.after')}
    </p>
    <div class="actions">
      <a href={localizePath('/ideas/', lang)} class="btn btn-accent">
        {t('nav.ideas')} <span class="arrow">↗</span>
      </a>
    </div>
    <div class="stats">
      <div class="stat">
        <span class="num">{posts.length}<span class="plus">+</span></span>
        <span class="label">{t('home.posts')}</span>
      </div>
      <div class="stat">
        <span class="num">{langCount}</span>
        <span class="label">{t('home.stats.languages')}</span>
      </div>
      <div class="stat">
        <span class="num"><span class="plus">∞</span></span>
        <span class="label">{t('home.stats.ideas')}</span>
      </div>
    </div>
  </div>

  <div class="about">
    <span class="badge">{t('about.badge')}</span>
    <h2>{t('about.heading')}</h2>
    <p class="about-text">{t('about.p1')}</p>
    <p class="label">{t('about.stackLabel')}</p>
    <div class="chips">
      {STACK.map((tech) => <span class="badge">{tech}</span>)}
    </div>
    <p class="about-text">{t('about.p2')}</p>
    <div class="projects">
      {
        PROJECTS.map((project) => (
          <a href={project.url} target="_blank" rel="noopener" class="project-card">
            <span class="project-label">{t('about.projectsLabel')}</span>
            <span class="project-name">
              {project.name} <span class="arrow">↗</span>
            </span>
          </a>
        ))
      }
    </div>
    <p class="about-text">{t('about.p3')}</p>
    <p class="about-text">{t('about.p4')}</p>
  </div>
  </article>

  <section class="posts-section">
    <div class="section-head">
      <div>
        <span class="badge">{t('home.posts.badge')}</span>
        <h2>{t('home.posts')}</h2>
      </div>
      <a href={localizePath('/blog/', lang)} class="btn">
        {t('home.viewAll')} <span class="arrow">↗</span>
      </a>
    </div>
    <PostList posts={posts.slice(0, 5)} />
  </section>
</Base>

<style>
  .hero {
    padding: 2.5rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }
  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    margin: 1.2rem 0 1rem;
  }
  .intro { max-width: 42rem; margin: 0.5rem 0; }
  .intro a { text-decoration: underline; }
  .actions { margin-top: 1.75rem; }

  .stats { display: flex; flex-wrap: wrap; margin-top: 2.75rem; }
  .stat {
    display: flex;
    flex-direction: column;
    padding: 0 2.5rem;
    border-left: 1px solid var(--border);
  }
  .stat:first-child { padding-left: 0; border-left: none; }
  .num {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 2rem;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.2;
  }
  .plus { color: var(--accent); }
  .label { color: var(--meta); font-size: 0.85rem; }

  .about {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
  }
  .about h2 { font-size: 1.9rem; margin: 0.9rem 0 0.5rem; }
  .about-text { max-width: 46rem; margin: 0.9rem 0; }
  .label {
    color: var(--meta);
    font-size: 0.85rem;
    margin: 1.4rem 0 0.5rem;
  }
  .chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .projects {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.9rem;
    margin: 1.2rem 0 1.6rem;
  }
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem;
    transition: border-color 0.15s ease;
  }
  .project-card:hover { border-color: var(--border-strong); text-decoration: none; }
  .project-label { color: var(--muted); font-size: 0.78rem; }
  .project-name { color: var(--text); font-weight: 500; }
  .project-name .arrow { color: var(--accent); }

  .posts-section { margin-top: 3rem; }
  .posts-section h2 {
    font-size: 1.9rem;
    margin: 0.9rem 0 0.5rem;
  }
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .section-head .btn { margin-bottom: 0.6rem; }
  @media (max-width: 640px) {
    .stat { padding: 0 1.5rem; }
    .projects { grid-template-columns: 1fr; }
  }
</style>
