---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { defaultLang, localizePath, useTranslations, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base title="Nick's Tech Blog">
  <h1>{t('home.greeting')}</h1>
  <p>{t('home.intro')}</p>
  <p>
    {t('home.ideas.before')}<a href={localizePath('/ideas/', lang)}>{t('home.ideas.link')}</a>{t('home.ideas.after')}
  </p>

  <h2>{t('home.posts')}</h2>
  <ul class="posts">
    {
      posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <span class="meta">
            {post.data.pubDate.toISOString().slice(0, 10)} ·{' '}
            {post.data.lang === 'vi' ? '🇻🇳' : '🇬🇧'}
          </span>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .posts { list-style: none; padding: 0; }
  .posts li { margin-bottom: 0.75rem; }
  .posts a { font-weight: 600; }
  .meta { display: block; color: var(--muted); font-size: 0.85rem; }
</style>
