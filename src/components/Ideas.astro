---
import Base from '../layouts/Base.astro';
import { defaultLang, useTranslations, type Lang } from '../i18n/ui';

/**
 * giscus config — comments/suggestions powered by GitHub Discussions.
 *
 * To activate (takes ~5 minutes):
 *  1. Push this repo to GitHub (public) and enable Discussions in repo Settings.
 *  2. Install the giscus app: https://github.com/apps/giscus
 *  3. Open https://giscus.app, pick your repo + an "Ideas" category,
 *     then copy `repoId` and `categoryId` from the generated snippet here.
 */
const GISCUS = {
  repo: 'your-github-username/tech-blog', // TODO
  repoId: '', // TODO
  category: 'Ideas',
  categoryId: '', // TODO
};

const configured = GISCUS.repoId !== '' && GISCUS.categoryId !== '';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
---

<Base title={t('ideas.title')} description={t('ideas.description')}>
  <h1>{t('ideas.heading')}</h1>
  <p>
    {t('ideas.p1')}<strong>{t('ideas.p1.strong')}</strong>
  </p>
  <p>{t('ideas.p2')}</p>
  {
    lang === 'en' && (
      <p lang="vi" class="vi-note">
        🇻🇳 Bạn cứ góp ý bằng tiếng Việt thoải mái nhé — mình đọc hết!
      </p>
    )
  }

  {
    configured ? (
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={GISCUS.repo}
        data-repo-id={GISCUS.repoId}
        data-category={GISCUS.category}
        data-category-id={GISCUS.categoryId}
        data-mapping="specific"
        data-term="blog-ideas"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="preferred_color_scheme"
        data-lang={lang}
        crossorigin="anonymous"
        async
      />
    ) : (
      <div class="setup-note">
        <p>
          <strong>Suggestions box coming soon.</strong> (Owner: follow the
          giscus setup steps in <code>src/components/Ideas.astro</code> to
          enable it.)
        </p>
      </div>
    )
  }
</Base>

<style>
  .vi-note { color: var(--muted); }
  .setup-note {
    border: 1px dashed var(--border);
    border-radius: 8px;
    padding: 0.25rem 1rem;
    color: var(--muted);
  }
</style>
