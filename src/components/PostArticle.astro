---
import { render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { localizePath, useTranslations } from '../i18n/ui';
import { postLang, type BlogPost } from '../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = post.data.pubDate.toISOString().slice(0, 10);
const lang = postLang(post);
const t = useTranslations(lang);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: date,
  inLanguage: lang,
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
  image: new URL('/og.png', Astro.site).toString(),
  author: { '@type': 'Person', name: 'Hai Truong', url: Astro.site?.toString() },
};
---

<Base
  title={`${post.data.title} · ${t('site.name')}`}
  description={post.data.description}
  ogType="article"
  schema={schema}
>
  <article class="prose">
    <p class="top-meta">
      <time datetime={date}>{date}</time>
      {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </p>
    <h1>{post.data.title}</h1>
    <p class="lead">{post.data.description}</p>
    <hr />
    <Content />
    <p class="back">
      <a href={localizePath('/', lang)}>← {t('nav.blog')}</a>
    </p>
  </article>
</Base>

<style>
  .top-meta { color: var(--meta); font-size: 0.85rem; margin: 1.5rem 0 1rem; }
  .prose h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    margin: 0.5rem 0 1rem;
  }
  .lead { font-size: 1.1rem; }
  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  .back { margin-top: 3rem; }
</style>
