---
import {
  defaultLang,
  languages,
  localizePath,
  translatePath,
  useTranslations,
  type Lang,
} from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  /** Override the UI language (used by post pages, which live on unprefixed URLs). */
  lang?: Lang;
}

const lang: Lang = Astro.props.lang ?? ((Astro.currentLocale ?? defaultLang) as Lang);
const t = useTranslations(lang);
const { title, description = t('site.description') } = Astro.props;

const otherLang = (Object.keys(languages) as Lang[]).find((l) => l !== lang)!;
const switchHref = translatePath(Astro.url.pathname, otherLang) ?? localizePath('/', otherLang);
const hasCounterpart = translatePath(Astro.url.pathname, lang) !== null;
const alternates = hasCounterpart
  ? (Object.keys(languages) as Lang[]).map((l) => ({
      hreflang: l,
      href: new URL(translatePath(Astro.url.pathname, l)!, Astro.site),
    }))
  : [];
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href={localizePath('/', lang)} class="brand">nick<span class="accent">.log</span></a>
        <div class="links">
          <a href={localizePath('/', lang)}>{t('nav.blog')}</a>
          <a href={localizePath('/ideas/', lang)}>{t('nav.ideas')}</a>
          <a href={switchHref} class="lang-switch">{languages[otherLang]}</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Nick · {t('footer.builtWith')}</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --text: #1f2937;
    --muted: #6b7280;
    --accent: #059669;
    --border: #e5e7eb;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0f1115;
      --text: #e5e7eb;
      --muted: #9ca3af;
      --accent: #34d399;
      --border: #262b33;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0 auto;
    max-width: 44rem;
    padding: 0 1.25rem;
    background: var(--bg);
    color: var(--text);
    font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
    line-height: 1.7;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  h1, h2, h3 { line-height: 1.3; }
  code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.9em;
    background: var(--border);
    padding: 0.15em 0.35em;
    border-radius: 4px;
  }
  pre { padding: 1rem; border-radius: 8px; overflow-x: auto; }
  pre code { background: none; padding: 0; }

  header nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .brand { font-weight: 700; font-size: 1.1rem; color: var(--text); }
  .brand .accent { color: var(--accent); }
  .links { display: flex; gap: 1.25rem; }
  .lang-switch { color: var(--muted); font-size: 0.9rem; }

  main { min-height: 60vh; padding: 2rem 0; }

  footer {
    border-top: 1px solid var(--border);
    padding: 1rem 0 2rem;
    color: var(--muted);
    font-size: 0.85rem;
  }
</style>
