---
import {
  defaultLang,
  languages,
  localizePath,
  translatePath,
  useTranslations,
  type Lang,
} from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  /** Open Graph object type — pass 'article' on post pages. */
  ogType?: 'website' | 'article';
  /** JSON-LD structured data — overrides the default WebSite schema. */
  schema?: Record<string, unknown>;
}

const lang: Lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const { title, description = t('site.description'), ogType = 'website', schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = schema ?? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t('site.name'),
  description: t('site.description'),
  url: new URL(localizePath('/', lang), Astro.site).toString(),
  inLanguage: lang,
  author: { '@type': 'Person', name: 'Hai Truong', url: Astro.site?.toString() },
};

const otherLang = (Object.keys(languages) as Lang[]).find((l) => l !== lang)!;
const switchHref = translatePath(Astro.url.pathname, otherLang) ?? localizePath('/', otherLang);
const hasCounterpart = translatePath(Astro.url.pathname, lang) !== null;
const alternates = hasCounterpart
  ? (Object.keys(languages) as Lang[]).map((l) => ({
      hreflang: l,
      href: new URL(translatePath(Astro.url.pathname, l)!, Astro.site),
    }))
  : [];
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={t('site.name')} />
    <meta property="og:locale" content={lang === 'vi' ? 'vi_VN' : 'en_US'} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600&family=Inter:wght@400;500&display=swap"
    />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href={localizePath('/', lang)} class="brand">haitruong<span class="accent">.log</span></a>
        <div class="links">
          <a href={localizePath('/', lang)} class="nav-link">{t('nav.blog')}</a>
          <a
            href="https://github.com/haitruong-tech/haitruong-tech.github.io"
            class="nav-link gh-link"
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
            title="GitHub"
          >
            <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
            </svg>
          </a>
          <a href={switchHref} class="btn btn-sm lang-switch">{languages[otherLang]}</a>
          <a href={localizePath('/ideas/', lang)} class="btn btn-sm btn-accent">{t('nav.ideas')}</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Hải Trương · {t('footer.builtWith')}</p>
      <div class="foot-links">
        <a href={localizePath('/', lang)}>{t('nav.blog')}</a>
        <a href={localizePath('/ideas/', lang)}>{t('nav.ideas')}</a>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Design tokens — adapted from the "AI Blog Website UI Template" (Produce UI).
     Dark shades: 08 #141414 (bg), 10 #1A1A1A (panel), 15 #262626 (border), 20 #333333 (hover border)
     Grey shades: 50 #7E7E81 (meta), 60 #98989A (muted body), 97 #F7F7F8 (text)
     Yellow 55 #FFD11A (accent). Headings: Be Vietnam Pro (Kumbh Sans swap for Vietnamese support). */
  :root {
    --bg: #141414;
    --panel: #1a1a1a;
    --border: #262626;
    --border-strong: #333333;
    --text: #f7f7f8;
    --muted: #98989a;
    --meta: #7e7e81;
    --accent: #ffd11a;
    --accent-hover: #ffd633;
    --accent-ink: #141414;
    --radius: 12px;
    --radius-sm: 10px;
    --font-heading: 'Be Vietnam Pro', ui-sans-serif, system-ui, sans-serif;
    --font-body: 'Inter', ui-sans-serif, system-ui, sans-serif;
  }
  * { box-sizing: border-box; }
  html { background: var(--bg); color-scheme: dark; }
  body {
    margin: 0 auto;
    max-width: 66rem;
    padding: 0 1.5rem;
    background: var(--bg);
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
  }
  h1, h2, h3, h4 {
    font-family: var(--font-heading);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--text);
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  strong { color: var(--text); font-weight: 600; }
  code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.9em;
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 0.12em 0.35em;
    border-radius: 6px;
  }
  pre {
    background: var(--panel) !important;
    border: 1px solid var(--border);
    padding: 1.1rem;
    border-radius: var(--radius);
    overflow-x: auto;
  }
  pre code { background: none; border: none; padding: 0; }
  ::selection { background: var(--accent); color: var(--accent-ink); }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* ---- shared components ---- */
  .badge {
    display: inline-block;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.25rem 0.7rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.6rem 1.1rem;
    color: var(--text);
    font-weight: 500;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .btn:hover { border-color: var(--border-strong); text-decoration: none; }
  .btn .arrow { color: var(--accent); }
  .btn-sm { padding: 0.4rem 0.8rem; font-size: 0.85rem; }
  .btn-accent {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-ink);
  }
  .btn-accent:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
  .btn-accent .arrow { color: var(--accent-ink); }
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  /* ---- article prose (post pages) ---- */
  .prose { max-width: 46rem; margin: 0 auto; }
  .prose p { color: var(--muted); }
  .prose h2 { font-size: 1.5rem; margin-top: 2.2rem; }
  .prose h3 { font-size: 1.2rem; }
  .prose li { margin-bottom: 0.35rem; }
  .prose blockquote {
    margin: 1.5rem 0;
    padding: 0.2rem 1.25rem;
    border-left: 3px solid var(--accent);
    background: var(--panel);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .prose img { max-width: 100%; border-radius: var(--radius); }

  /* ---- header ---- */
  header nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .brand {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .brand:hover { text-decoration: none; }
  .brand .accent { color: var(--accent); }
  .links { display: flex; gap: 0.9rem; align-items: center; flex-wrap: wrap; }
  .nav-link { color: var(--muted); font-size: 0.95rem; }
  .nav-link:hover { color: var(--text); text-decoration: none; }
  .gh-link { display: inline-flex; align-items: center; }
  .gh-link svg { display: block; }
  .links .btn:hover { text-decoration: none; }

  main { min-height: 60vh; padding: 2.5rem 0; }

  /* ---- footer ---- */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 1.5rem 0 2.5rem;
    color: var(--meta);
    font-size: 0.85rem;
  }
  footer p { margin: 0; }
  .foot-links { display: flex; gap: 1.25rem; }
  .foot-links a { color: var(--meta); }
  .foot-links a:hover { color: var(--text); text-decoration: none; }
</style>
